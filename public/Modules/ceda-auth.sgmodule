#!name=Ceda Auth
#!desc=自动注入 API 验证所需的 Authorization Header
#!category=Ceda.is
#!arguments=Auth:鉴权Token

[Header Rewrite]
^https?://nanobase\.ceda\.is/api/upload header-add Authorization "Bearer {{{Auth}}}"
^https?://tinge\.ceda\.is/api/ header-add Authorization "Bearer {{{Auth}}}"
^https?://prompt\.ceda\.is/api/ header-add Authorization "Bearer {{{Auth}}}"

[MITM]
hostname = %APPEND% nanobase.ceda.is, tinge.ceda.is, prompt.ceda.is
